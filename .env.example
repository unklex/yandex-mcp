# ============================================================
# Yandex Metrica (обязательно)
# ============================================================
YANDEX_METRICA_TOKEN=your_oauth_token_here
YANDEX_METRICA_COUNTER_ID=12345678

# Несколько счётчиков (необязательно): alias:id,alias2:id2
# YANDEX_METRICA_COUNTERS=site1:12345678,site2:87654321

# ============================================================
# Yandex Direct (необязательно)
# ============================================================
# Несколько аккаунтов (рекомендуется): alias:token,alias2:token2
# YANDEX_DIRECT_ACCOUNTS=promreo:AQAAAABxxx,site2:AQAAAAByyy

# Или один аккаунт:
# YANDEX_DIRECT_TOKEN=your_direct_oauth_token_here

# Логин клиента для агентских аккаунтов (необязательно):
# YANDEX_DIRECT_CLIENT_LOGIN=client-login-here

# ============================================================
# OAuth приложение (для получения токенов)
# ============================================================
